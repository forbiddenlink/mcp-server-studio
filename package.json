{
  "name": "mcp-server-studio",
  "version": "1.0.0",
  "description": "Visual builder for Model Context Protocol servers - design, test, and export MCP servers with drag-and-drop",
  "author": "Liz Stein",
  "license": "MIT",
  "private": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/mcp-server-studio"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai",
    "llm",
    "tools",
    "visual-builder",
    "code-generator",
    "typescript"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "test": "vitest",
    "test:run": "vitest run",
    "presubmit": "pnpm lint && pnpm test:run && pnpm build",
    "prepare": "husky",
    "biome:check": "biome check .",
    "biome:fix": "biome check . --write",
    "biome:format": "biome format . --write",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix"
    ]
  },
  "dependencies": {
    "@arcjet/next": "^1.3.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@monaco-editor/react": "^4.7.0",
    "@sentry/nextjs": "^10.47.0",
    "@t3-oss/env-nextjs": "^0.13.11",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "@vercel/speed-insights": "^2.0.0",
    "@xyflow/react": "^12.10.1",
    "ajv": "^8.18.0",
    "canvas-confetti": "^1.9.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.34.3",
    "js-yaml": "^4.1.1",
    "json-schema-to-typescript": "^15.0.4",
    "jszip": "^3.10.1",
    "lucide-react": "^0.575.0",
    "next": "16.1.7",
    "next-axiom": "^1.5.0",
    "next-safe-action": "^8.3.0",
    "nuqs": "^2.8.9",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "tailwind-merge": "^3.5.0",
    "zod-to-json-schema": "^3.25.2",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@next/bundle-analyzer": "^16.2.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/canvas-confetti": "^1.9.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.1.4",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.3.2",
    "msw": "^2.12.14",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typedoc": "^0.28.18",
    "typedoc-plugin-markdown": "^4.11.0",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}